– ─────────────────────────────────────────
– 3. PRODUCTS (商品主檔)
–    avg_cost 使用加權平均成本法動態更新
– ─────────────────────────────────────────
CREATE TABLE products (
id            UUID PRIMARY KEY DEFAULT uuid_generate_v4(),
sku           VARCHAR(50)   UNIQUE NOT NULL,
name          VARCHAR(100)  NOT NULL,
unit          VARCHAR(20)   NOT NULL DEFAULT ‘個’,   – 盒, 包, 台, 卷…
supplier_id   UUID          REFERENCES suppliers(id),
avg_cost      NUMERIC(12,4) NOT NULL DEFAULT 0,      – 加權平均成本
threshold     INTEGER       NOT NULL DEFAULT 50,     – 安全庫存水位
description   TEXT,
is_active     BOOLEAN       NOT NULL DEFAULT TRUE,
created_at    TIMESTAMPTZ   NOT NULL DEFAULT NOW(),
updated_at    TIMESTAMPTZ   NOT NULL DEFAULT NOW()
);

– ─────────────────────────────────────────
– 4. INVENTORY (各地點庫存快照)
–    每個 location 對每個 product 維護一筆
– ─────────────────────────────────────────
CREATE TABLE inventory (
id           UUID PRIMARY KEY DEFAULT uuid_generate_v4(),
location_id  UUID          NOT NULL REFERENCES locations(id),
product_id   UUID          NOT NULL REFERENCES products(id),
quantity     INTEGER       NOT NULL DEFAULT 0 CHECK (quantity >= 0),
updated_at   TIMESTAMPTZ   NOT NULL DEFAULT NOW(),
UNIQUE (location_id, product_id)
);

– ─────────────────────────────────────────
– 5. TRANSACTIONS (異動記錄 — 核心流水帳)
–    記錄所有入庫、出庫、調撥
– ─────────────────────────────────────────
CREATE TYPE transaction_type AS ENUM (
‘inbound’,      – 供應商進貨入中心倉庫
‘outbound’,     – 分店領貨出中心倉庫
‘transfer’,     – 地點間調撥
‘adjustment’    – 盤點調整
);

CREATE TABLE transactions (
id             UUID             PRIMARY KEY DEFAULT uuid_generate_v4(),
type           transaction_type NOT NULL,
product_id     UUID             NOT NULL REFERENCES products(id),
from_location  UUID             REFERENCES locations(id),  – NULL = 外部供應商
to_location    UUID             REFERENCES locations(id),  – NULL = 外部銷售
supplier_id    UUID             REFERENCES suppliers(id),  – 進貨時填入
quantity       INTEGER          NOT NULL CHECK (quantity > 0),
unit_price     NUMERIC(12,4),   – 本次交易單價（進貨才有）
total_amount   NUMERIC(14,4),   – = quantity * unit_price
operator       VARCHAR(50),     – 操作人員姓名
note           TEXT,
created_at     TIMESTAMPTZ      NOT NULL DEFAULT NOW()
);

– ─────────────────────────────────────────
– 6. INDEXES (查詢效能優化)
– ─────────────────────────────────────────
CREATE INDEX idx_transactions_product   ON transactions(product_id);
CREATE INDEX idx_transactions_created   ON transactions(created_at DESC);
CREATE INDEX idx_transactions_type      ON transactions(type);
CREATE INDEX idx_inventory_location     ON inventory(location_id);
CREATE INDEX idx_inventory_product      ON inventory(product_id);

– ─────────────────────────────────────────
– 7. TRIGGER: 自動更新 avg_cost (加權平均成本)
–    僅在 inbound 時觸發
– ─────────────────────────────────────────
CREATE OR REPLACE FUNCTION update_avg_cost()
RETURNS TRIGGER AS $$
DECLARE
current_qty   INTEGER;
current_cost  NUMERIC(12,4);
new_cost      NUMERIC(12,4);
BEGIN
– 只處理進貨且有單價的情況
IF NEW.type = ‘inbound’ AND NEW.unit_price IS NOT NULL THEN
SELECT COALESCE(SUM(quantity), 0), p.avg_cost
INTO current_qty, current_cost
FROM inventory i
JOIN products p ON p.id = NEW.product_id
WHERE i.product_id = NEW.product_id
GROUP BY p.avg_cost
LIMIT 1;

```
    -- 加權平均成本公式
    new_cost := (current_qty * current_cost + NEW.quantity * NEW.unit_price)
                / NULLIF(current_qty + NEW.quantity, 0);

    UPDATE products SET avg_cost = new_cost, updated_at = NOW()
    WHERE id = NEW.product_id;
END IF;
RETURN NEW;
```

END;
$$ LANGUAGE plpgsql;

CREATE TRIGGER trg_avg_cost
AFTER INSERT ON transactions
FOR EACH ROW EXECUTE FUNCTION update_avg_cost();

