– 8. VIEW: 庫存彙總（供 Dashboard API 使用）
– ─────────────────────────────────────────
CREATE VIEW v_inventory_summary AS
SELECT
p.id            AS product_id,
p.sku,
p.name          AS product_name,
p.unit,
p.avg_cost,
p.threshold,
s.name          AS supplier_name,
s.phone         AS supplier_phone,
l.name          AS location_name,
l.type          AS location_type,
i.quantity,
i.quantity * p.avg_cost AS stock_value,
(i.quantity < p.threshold) AS is_low_stock
FROM inventory i
JOIN products  p ON p.id = i.product_id
JOIN locations l ON l.id = i.location_id
LEFT JOIN suppliers s ON s.id = p.supplier_id
WHERE l.is_active = TRUE AND p.is_active = TRUE;

– ─────────────────────────────────────────
– 9. VIEW: 每日分店流向（供 Discord Daily Digest）
– ─────────────────────────────────────────
CREATE VIEW v_daily_digest AS
SELECT
DATE(t.created_at AT TIME ZONE ‘Asia/Taipei’) AS txn_date,
l.name          AS location_name,
p.name          AS product_name,
p.unit,
SUM(t.quantity) AS total_out,
p.avg_cost,
s.name          AS supplier_name,
s.phone         AS supplier_phone
FROM transactions t
JOIN products  p ON p.id = t.product_id
JOIN locations l ON l.id = t.to_location
LEFT JOIN suppliers s ON s.id = p.supplier_id
WHERE t.type = ‘outbound’
GROUP BY 1, 2, 3, 4, p.avg_cost, 7, 8
ORDER BY 1 DESC, 2, 3;