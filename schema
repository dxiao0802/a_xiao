– ─────────────────────────────────────────
– 0. EXTENSIONS
– ─────────────────────────────────────────
CREATE EXTENSION IF NOT EXISTS “uuid-ossp”;

– ─────────────────────────────────────────
– 1. LOCATIONS (倉庫 / 分店節點)
–    支援自主新增分店，type 區分中心/分支
– ─────────────────────────────────────────
CREATE TABLE locations (
id          UUID PRIMARY KEY DEFAULT uuid_generate_v4(),
name        VARCHAR(50)  NOT NULL,                   – e.g. ‘大西倉庫’, ‘士捷分店’
type        VARCHAR(20)  NOT NULL                    – ‘warehouse’ | ‘branch’
CHECK (type IN (‘warehouse’, ‘branch’)),
address     TEXT,
phone       VARCHAR(30),
is_active   BOOLEAN      NOT NULL DEFAULT TRUE,      – 軟刪除支援
created_at  TIMESTAMPTZ  NOT NULL DEFAULT NOW(),
updated_at  TIMESTAMPTZ  NOT NULL DEFAULT NOW()
);

